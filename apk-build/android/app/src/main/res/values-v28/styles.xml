<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- shortEdges: render into the notch/camera cutout zone in landscape so the track isn't
         clipped to one side of a punch-hole camera. The game already pads its HUD with
         env(safe-area-inset-*), so UI stays clear of the cutout. -->
    <style name="AppTheme.NoActionBar">
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
