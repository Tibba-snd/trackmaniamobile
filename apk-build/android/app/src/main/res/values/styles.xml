<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Black behind everything so the translucent system-bar / splash handoff never shows white. -->
        <item name="android:colorBackground">@color/black</item>
    </style>


    <!-- Launch theme: the Activity opens with this until Capacitor's WebView paints its first frame.
         `postSplashScreenTheme` switches to the no-action-bar runtime theme as soon as the
         splash screen finishes. Without it, Theme.SplashScreen can retain its purple title bar.
         Default @drawable/splash is a white PNG with the Capacitor "X" logo — that was the original
         white bar. Now solid black: the game canvas paints black, so handoff is seamless + logo-free. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:background">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Kill the title/action bar. Theme.SplashScreen leaks an ActionBar on some AppCompat
             setups; its background is colorPrimary (purple #9d7bff) and it shows the activity
             label "DRIFTDREAM" white/left-aligned — exactly the ~10% purple band seen at the top. -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
