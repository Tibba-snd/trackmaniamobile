<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Black behind everything so the translucent system-bar / splash handoff never shows white. -->
        <item name="android:colorBackground">@color/black</item>
    </style>


    <!-- Launch theme: the Activity opens with this until Capacitor's WebView paints its first frame.
         Capacitor does NOT call installSplashScreen(), so the postSplashScreenTheme swap never fires
         and the Activity keeps running under this theme for its entire lifetime. That means every
         fullscreen flag must live HERE, not just in AppTheme.NoActionBar:
           - windowFullscreen=true tells the OS the window wants no status bar (the reserved strip
             you saw was the status-bar inset; the purple you saw was the menu gradient bleeding
             into it once the WebView started drawing behind it).
           - The runtime WindowInsetsController.hide() in MainActivity handles nav-bar hiding and
             the immersive-sticky re-assert on focus regain.
         Default @drawable/splash is a white PNG with the Capacitor "X" logo — that was the original
         white bar. Now solid black: the game canvas paints black, so handoff is seamless + logo-free. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>