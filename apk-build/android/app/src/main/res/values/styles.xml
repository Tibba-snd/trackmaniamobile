<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Black behind everything so the translucent system-bar / splash handoff never shows white. -->
        <item name="android:colorBackground">@color/black</item>
    </style>


    <!-- Launch theme: the Activity opens with this until Capacitor's WebView paints its first frame.
         Capacitor does NOT call installSplashScreen(), so the postSplashScreenTheme swap never fires
         and the launch theme's background lingers wherever the WebView is transparent at the edges.
         The default @drawable/splash is a white PNG with the Capacitor "X" logo — that white + logo
         is exactly the bar + placeholder icons seen at the top on cold start. Use solid black instead:
         the game canvas paints black anyway, so the handoff is seamless and logo-free. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
    </style>
</resources>